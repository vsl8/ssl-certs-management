# SSL Cert Manager Environment Configuration
# Copy this file to .env and customize as needed

# Flask secret key (REQUIRED for production - generate a strong random key)
SECRET_KEY=change-me-in-production-use-strong-key

# Database configuration
# Options: sqlite (default) or mariadb
DB_TYPE=sqlite

# MariaDB configuration (only needed if DB_TYPE=mariadb)
# DB_HOST=mariadb
# DB_PORT=3306
# DB_NAME=certmanager
# DB_USER=certmanager
# DB_PASS=secure-password
